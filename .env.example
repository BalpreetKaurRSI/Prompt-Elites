OPENAI_API_KEY=sk-your-openai-api-key-here

# AWS Configuration
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Set to "true" to use DynamoDB Local + LocalStack (no AWS account needed)
AWS_LOCAL=true

# S3 Configuration
S3_BUCKET_NAME=ai-sdlc-documents

# DynamoDB Table Names
DYNAMODB_REQUIREMENTS_TABLE=requirements
DYNAMODB_ARTIFACTS_TABLE=artifacts
